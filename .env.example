# Copy this file to .env and fill values for your local environment.

USE_MEDGEMMA=true
REQUIRE_MEDGEMMA=false
MEDGEMMA_BASE_URL=
MEDGEMMA_API_KEY=
MEDGEMMA_MODEL=medgemma
MEDGEMMA_API_STYLE=openai_chat
MEDGEMMA_GENERATE_PATH=/generate

FHIR_BASE_URL=
FHIR_ACCESS_TOKEN=
FHIR_AUTH_TYPE=STATIC_BEARER
FHIR_TOKEN_URL=
FHIR_CLIENT_ID=
FHIR_CLIENT_SECRET=
FHIR_CLIENT_AUTH_METHOD=client_secret_basic
FHIR_SCOPE=system/Patient.read system/Patient.search system/Coverage.read system/Coverage.search system/Encounter.read system/Encounter.search system/Practitioner.read system/Practitioner.search system/Organization.read system/Organization.search system/Condition.read system/Condition.search system/Procedure.read system/Procedure.search system/DocumentReference.read system/DocumentReference.search system/ChargeItem.read system/ChargeItem.search
FHIR_AUDIENCE=
FHIR_PRIVATE_KEY_PATH=./keys/nonprod/private.pem
FHIR_KEY_ID=
FHIR_JWKS_URL=

NPHIES_SOURCE_ENDPOINT=https://velodoc.ai/fhir

DEFAULT_TRIGGER_SOURCE=VELO_DOCTOR_APPROVED_ENCOUNTER
DEFAULT_CLAIM_FORMAT=AUTO
DEFAULT_JURISDICTION=AUTO
