# Copy this file to .env and fill values for your local environment.

USE_MEDGEMMA=true
REQUIRE_MEDGEMMA=false
MEDGEMMA_BASE_URL=
MEDGEMMA_API_KEY=
MEDGEMMA_MODEL=medgemma
MEDGEMMA_API_STYLE=openai_chat
MEDGEMMA_GENERATE_PATH=/generate

USE_VALIDATION_KG=true
VALIDATION_KG_PATH=./data/coding_knowledge_graph.json
USE_VALIDATION_LLM=false
VALIDATION_LLM_BASE_URL=
VALIDATION_LLM_API_KEY=
VALIDATION_LLM_MODEL=medgemma
VALIDATION_LLM_API_STYLE=openai_chat
VALIDATION_LLM_GENERATE_PATH=/generate

# FHIR_ADAPTER chooses the EHR/HIE profile behind the common FHIR reader.
# Supported: generic, epic, trakcare_iris, oracle_health, nabidh
FHIR_ADAPTER=generic
FHIR_BASE_URL=
FHIR_ACCESS_TOKEN=
FHIR_AUTH_TYPE=STATIC_BEARER
FHIR_TOKEN_URL=
FHIR_CLIENT_ID=
FHIR_CLIENT_SECRET=
FHIR_CLIENT_AUTH_METHOD=client_secret_basic
FHIR_SCOPE=system/Patient.read system/Patient.search system/Coverage.read system/Coverage.search system/Encounter.read system/Encounter.search system/Practitioner.read system/Practitioner.search system/Organization.read system/Organization.search system/Condition.read system/Condition.search system/Procedure.read system/Procedure.search system/DocumentReference.read system/DocumentReference.search system/ChargeItem.read system/ChargeItem.search
FHIR_AUDIENCE=
FHIR_PRIVATE_KEY_PATH=./keys/nonprod/private.pem
FHIR_KEY_ID=
FHIR_JWKS_URL=
FHIR_TIMEOUT_SECONDS=30

# Epic profile. If empty, the adapter falls back to the generic FHIR_* values.
EPIC_FHIR_BASE_URL=
EPIC_FHIR_AUTH_TYPE=
EPIC_FHIR_TOKEN_URL=
EPIC_FHIR_CLIENT_ID=
EPIC_FHIR_CLIENT_SECRET=
EPIC_FHIR_CLIENT_AUTH_METHOD=
EPIC_FHIR_SCOPE=
EPIC_FHIR_AUDIENCE=
EPIC_FHIR_PRIVATE_KEY_PATH=
EPIC_FHIR_KEY_ID=
EPIC_FHIR_JWKS_URL=

# InterSystems TrakCare / IRIS for Health profile.
TRAKCARE_FHIR_BASE_URL=
TRAKCARE_FHIR_AUTH_TYPE=
TRAKCARE_FHIR_TOKEN_URL=
TRAKCARE_FHIR_CLIENT_ID=
TRAKCARE_FHIR_CLIENT_SECRET=
TRAKCARE_FHIR_CLIENT_AUTH_METHOD=
TRAKCARE_FHIR_SCOPE=
TRAKCARE_FHIR_AUDIENCE=
TRAKCARE_FHIR_PRIVATE_KEY_PATH=
TRAKCARE_FHIR_KEY_ID=
TRAKCARE_FHIR_JWKS_URL=

# Oracle Health / Cerner Millennium profile.
ORACLE_HEALTH_FHIR_BASE_URL=
ORACLE_HEALTH_FHIR_AUTH_TYPE=
ORACLE_HEALTH_FHIR_TOKEN_URL=
ORACLE_HEALTH_FHIR_CLIENT_ID=
ORACLE_HEALTH_FHIR_CLIENT_SECRET=
ORACLE_HEALTH_FHIR_CLIENT_AUTH_METHOD=
ORACLE_HEALTH_FHIR_SCOPE=
ORACLE_HEALTH_FHIR_AUDIENCE=
ORACLE_HEALTH_FHIR_PRIVATE_KEY_PATH=
ORACLE_HEALTH_FHIR_KEY_ID=
ORACLE_HEALTH_FHIR_JWKS_URL=

# NABIDH Dubai HIE profile.
NABIDH_FHIR_BASE_URL=
NABIDH_FHIR_AUTH_TYPE=
NABIDH_FHIR_TOKEN_URL=
NABIDH_FHIR_CLIENT_ID=
NABIDH_FHIR_CLIENT_SECRET=
NABIDH_FHIR_CLIENT_AUTH_METHOD=
NABIDH_FHIR_SCOPE=
NABIDH_FHIR_AUDIENCE=
NABIDH_FHIR_PRIVATE_KEY_PATH=
NABIDH_FHIR_KEY_ID=
NABIDH_FHIR_JWKS_URL=

NPHIES_SOURCE_ENDPOINT=https://velodoc.ai/fhir
NPHIES_PROCESS_MESSAGE_URL=
NPHIES_PRIOR_AUTH_URL=
SHAFAFIYA_PRIOR_AUTH_URL=
ECLAIMLINK_PRIOR_AUTH_URL=
PRIOR_AUTH_ENDPOINT_URL=
PRIOR_AUTH_POLL_URL=
PRIOR_AUTH_ACCESS_TOKEN=
PRIOR_AUTH_DRY_RUN=true
PRIOR_AUTH_AUTO_SUBMIT=false
PRIOR_AUTH_POLL_ENABLED=false
PRIOR_AUTH_DRY_RUN_STATUS=queued
PRIOR_AUTH_DRY_RUN_FINAL_STATUS=
PRIOR_AUTH_DRY_RUN_FINAL_DECISION=

DEFAULT_TRIGGER_SOURCE=VELO_DOCTOR_APPROVED_ENCOUNTER
DEFAULT_CLAIM_FORMAT=AUTO
DEFAULT_JURISDICTION=AUTO
